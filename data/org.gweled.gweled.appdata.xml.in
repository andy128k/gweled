<component type="desktop">
  <id>org.gweled.gweled</id>
  <name>Gweled</name>
  <summary>Bejeweled like real time strategic puzzle game</summary>
  <description>
   <p>Gweled is a GTK+ version of a popular PalmOS/Windows/Java game called &#34;Bejeweled&#34;, originally written by Sebastien Delestaing. The aim of the game is to make alignment of 3 or more gems, both vertically or horizontally by swapping adjacent gems. The game ends when there are no possible moves left.</p>
  </description>

  <launchable type="desktop-id">gweled.desktop</launchable>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0+ and GFDL-1.3</project_license>

  <url type="homepage">https://gweled.org/</url>
  <url type="bugtracker">https://bugs.launchpad.net/gweled</url>
  <url type="translate">https://translations.launchpad.net/gweled</url>
  <url type="donate">https://liberapay.com/Gweled/</url>

  <update_contact>dnax88@gmail.com</update_contact>
  <developer_name>Daniele Napolitano</developer_name>
  
  <supports>
    <control>pointing</control>
    <control>touch</control>
  </supports>

  <screenshots>
    <screenshot type="default">
      <image type="source">https://gweled.org/images/screen1.png</image>
    </screenshot>
  </screenshots>

  <translation type="gettext">gweled</translation>
 
  <project_group>GNOME</project_group>
  <content_rating type="oars-1.1"/>
</component>
