msgid "Normal"
msgstr "Normál"

#: ../src/main.c:66
msgctxt "game type"
msgid "Timed"
msgstr "Időre megy"

#: ../src/main.c:280
msgid "Game over!"
msgstr "Vége a játéknak!"

#: ../src/main.c:282
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr "Remek munka, de a pontszáma sajnos nincs benne az első tízben."

#: ../src/main.c:284
msgid "_New Game"
msgstr "Ú_j játék"

#: ../src/main.c:296
msgid "Gweled Scores"
msgstr "Gweled pontok"

#: ../src/main.c:299
msgid "Game type:"
msgstr "Játéktípus:"

#: ../src/main.c:306
msgid "Congratulations!"
msgstr "Gratulálunk!"

#: ../src/main.c:307
msgid "Your score is the best!"
msgstr "Pontszáma a legjobb!"

#: ../src/main.c:308
msgid "Your score has made the top ten."
msgstr "Pontszáma benne van az első tízben."

#: ../src/main.c:397
msgid "Get as many point as you can. The game ends if you out of moves."
msgstr ""
"Szerezzen annyi pontot, amennyit csak tud. A játéknak akkor van vége, ha "
"nincs több lépés."

#: ../src/main.c:399
msgid "Get as many points as you can, but you are limited on time."
msgstr "Szerezzen annyi pontot, amennyit csak tud, de az időhatáron belül."

#: ../src/main.c:401
msgid "Game will never end. Your scores will not be registered."
msgstr "A játék sosem ér véget. A pontszáma nem lesz eltárolva."

#: ../src/main.c:461
msgid "There is a game saved, do you want restore it?"
msgstr "Van elmentett játék, szeretné folytatni?"

#: ../src/callbacks.c:74
msgid "Do you really want to abort this game?"
msgstr "Biztosan abbahagyja ezt a játékot?"

#: ../src/callbacks.c:139
msgid "Do you want to save the current game?"
msgstr "Szeretné elmenteni az aktuális játékot?"

#: ../src/callbacks.c:173
msgid "translator-credits"
msgstr ""
"Launchpad Contributions:\n"
"  Úr Balázs https://launchpad.net/~urbalazs"

#: ../src/callbacks.c:178
msgid "A puzzle game with gems"
msgstr "Puzzle-játék drágakövekkel"

