#: src/main.c:280
msgid "Game over!"
msgstr "Vége a játéknak!"

#: src/main.c:282
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr "Remek munka, de a pontszáma sajnos nincs benne az első tízben."

#: src/main.c:284
msgid "_New Game"
msgstr "Ú_j játék"

#: src/main.c:296
msgid "Gweled Scores"
msgstr "Gweled pontok"

#: src/main.c:299
msgid "Game type:"
msgstr "Játéktípus:"

#: src/main.c:306
msgid "Congratulations!"
msgstr "Gratulálunk!"

#: src/main.c:307
msgid "Your score is the best!"
msgstr "Pontszáma a legjobb!"

#: src/main.c:308
msgid "Your score has made the top ten."
msgstr "Pontszáma benne van az első tízben."

#: src/main.c:396
msgid "Get as many points as you can. The game ends if you run out of moves."
msgstr ""
"Szerezzen annyit pontot, amennyit csak tud. A játéknak akkor van vége, ha "
"már nem tud többet lépni."

#: src/main.c:398
msgid "Get as many points as you can. The game ends if you run out of time."
msgstr ""
"Szerezzen annyit pontot, amennyit csak tud. A játéknak akkor van vége, ha "
"elfogy az ideje."

#: src/main.c:400
msgid "The game never ends, but your score will not be saved."
msgstr "A játéknak sosincs vége, de a pontszáma nem lesz elmentve."

#: src/main.c:452
msgid "There is a game saved, do you want restore it?"
msgstr "Van elmentett játék, szeretné folytatni?"

#: src/callbacks.c:73
msgid "Do you really want to abort this game?"
msgstr "Biztosan abbahagyja ezt a játékot?"

#: src/callbacks.c:138
msgid "Do you want to save the current game?"
msgstr "Szeretné elmenteni az aktuális játékot?"

#: src/callbacks.c:173
msgid "translator-credits"
msgstr ""
"Launchpad Contributions:\n"
"  Úr Balázs https://launchpad.net/~urbalazs"

