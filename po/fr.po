#: src/main.c:280
msgid "Game over!"
msgstr "Perdu !"

#: src/main.c:282
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr ""
"Bien joué, mais malheureusement votre score n'entre pas dans le top 10."

#: src/main.c:284
msgid "_New Game"
msgstr "_Nouvelle partie"

#: src/main.c:296
msgid "Gweled Scores"
msgstr "Scores Gweled"

#: src/main.c:299
msgid "Game type:"
msgstr "Type de jeu :"

#: src/main.c:306
msgid "Congratulations!"
msgstr "Félicitations !"

#: src/main.c:307
msgid "Your score is the best!"
msgstr "Vous avez fait le meilleur score !"

#: src/main.c:308
msgid "Your score has made the top ten."
msgstr "Votre score est entré dans le top 10."

#: src/main.c:396
msgid "Get as many points as you can. The game ends if you run out of moves."
msgstr ""
"Essayez d'avoir le score le plus grand possible. Le jeu prend fin quand il "
"n'y a plus de mouvements possible."

#: src/main.c:398
msgid "Get as many points as you can. The game ends if you run out of time."
msgstr ""
"Essayez d'avoir le score le plus grand possible. Le jeu prend fin quand le "
"chrono arrive à 0."

#: src/main.c:400
msgid "The game never ends, but your score will not be saved."
msgstr "Le jeu ne prend jamais fin, mais votre score ne sera pas enregistré."

#: src/main.c:452
msgid "There is a game saved, do you want restore it?"
msgstr "Il existe une partie sauvegardée, voulez vous la continuer ?"

#: src/callbacks.c:73
msgid "Do you really want to abort this game?"
msgstr "Voulez-vous vraiment arrêter cette partie ?"

#: src/callbacks.c:138
msgid "Do you want to save the current game?"
msgstr "Voulez-vous sauvegarder la partie en cours ?"

