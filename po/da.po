#: src/main.c:280
msgid "Game over!"
msgstr "Spillet er slut!"

#: src/main.c:282
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr "Godt arbejde, men desværre kom dit resultat ikke på top ti."

#: src/main.c:284
msgid "_New Game"
msgstr "_Nyt spil"

#: src/main.c:296
msgid "Gweled Scores"
msgstr "Gweledresultater"

#: src/main.c:299
msgid "Game type:"
msgstr "Spiltype:"

#: src/main.c:306
msgid "Congratulations!"
msgstr "Tillykke!"

#: src/main.c:307
msgid "Your score is the best!"
msgstr "Du har opnået det bedste resultat!"

#: src/main.c:308
msgid "Your score has made the top ten."
msgstr "Dit resultat kom på top ti."

#: src/main.c:396
msgid "Get as many points as you can. The game ends if you run out of moves."
msgstr ""
"Saml så mange point som du kan. Spillet slutter, når du ikke har flere "
"muligheder for at flytte."

#: src/main.c:398
msgid "Get as many points as you can. The game ends if you run out of time."
msgstr ""
"Saml så mange point som du kan. Spillet slutter, når du ikke har mere tid "
"tilbage."

#: src/main.c:400
msgid "The game never ends, but your score will not be saved."
msgstr "Spillet slutter aldrig, men din score bliver ikke gemt."

#: src/main.c:452
msgid "There is a game saved, do you want restore it?"
msgstr "Der er et gemt spil, ønsker du at gendanne det?"

#: src/callbacks.c:73
msgid "Do you really want to abort this game?"
msgstr "Vil du virkelig afbryde spillet?"

#: src/callbacks.c:138
msgid "Do you want to save the current game?"
msgstr "Ønsker du at gemme det aktuelle spil?"

