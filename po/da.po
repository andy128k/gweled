#: ../src/main.c:280
msgid "Game over!"
msgstr "Spillet er slut!"

#: ../src/main.c:282
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr "Godt arbejde, men desværre kom dit resultat ikke på top ti."

#: ../src/main.c:284
