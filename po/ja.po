msgid "Normal"
msgstr "ノーマル"

#: ../src/main.c:66
msgctxt "game type"
msgid "Timed"
msgstr "タイムアタック"

#: ../src/main.c:291
msgid "Game over!"
msgstr "ゲーム終了！"

#: ../src/main.c:293
msgid "Great work, but unfortunately your score did not make the top ten."
msgstr ""
"よく頑張りましたね。でも残念ながら、トップ１０にはランクインできませんでし"
"た。"

#: ../src/main.c:295
msgid "_New Game"
msgstr "新しいゲーム(_N)"

#: ../src/main.c:307
msgid "Gweled Scores"
msgstr "Gweledのハイスコア"

#: ../src/main.c:310
msgid "Game type:"
msgstr "ゲームタイプ:"

#: ../src/main.c:317
msgid "Congratulations!"
msgstr "おめでとう！"

#: ../src/main.c:318
msgid "Your score is the best!"
msgstr "あなたがトップになりました！"

#: ../src/main.c:319
msgid "Your score has made the top ten."
msgstr "トップ１０にランクインしました。"

#: ../src/main.c:408
msgid "Get as many points as you can. The game ends if you run out of moves."
msgstr ""
"あなたはできるだけ多くのポイントをとってください。ゲームは動きが尽きた時点で"
"終了します。"

#: ../src/main.c:410
msgid "Get as many points as you can. The game ends if you run out of time."
msgstr ""
"あなたはできるだけ多くのポイントをとってください。ゲームは時間が不足した時点"
"で終了します。"

#: ../src/main.c:412
msgid "The game never ends, but your score will not be saved."
msgstr "ゲームが終わることはありませんが、あなたのスコアは保存されません。"

#: ../src/main.c:469
msgid "There is a game saved, do you want restore it?"
msgstr "以前からの保存ゲームがあります。再開しますか？"

#: ../src/callbacks.c:73
msgid "Do you really want to abort this game?"
msgstr "本当に終了しますか？"

#: ../src/callbacks.c:138
msgid "Do you want to save the current game?"
msgstr "今のゲームを保存しますか？"

#: ../src/callbacks.c:173
msgid "translator-credits"
msgstr ""
